@model LoginDto
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Car Rental | Giriş Yap</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(rgba(30, 30, 47, 0.8), rgba(30, 30, 47, 0.9)), url('https://images.unsplash.com/photo-1492144534655-ae79c964c9d7?auto=format&fit=crop&q=80&w=1920');
            background-size: cover;
            background-position: center;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
        }

        .login-card {
            background: rgba(255, 255, 255, 0.07);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border-radius: 20px;
            padding: 40px;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 25px 50px rgba(0,0,0,0.3);
            border: 1px solid rgba(255,255,255,0.1);
        }

        .brand-logo {
            font-size: 2.5rem;
            font-weight: 800;
            background: linear-gradient(to right, #f39c12, #ffcc33);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-align: center;
            margin-bottom: 5px;
            letter-spacing: -1px;
        }

        .form-control {
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: #fff;
            border-radius: 10px;
            padding: 12px 15px;
            transition: all 0.3s ease;
        }

            .form-control:focus {
                background: rgba(255, 255, 255, 0.15);
                color: #fff;
                border-color: #f39c12;
                box-shadow: 0 0 15px rgba(243, 156, 18, 0.3);
            }

        .btn-login {
            background: linear-gradient(45deg, #f39c12, #e67e22);
            border: none;
            border-radius: 10px;
            font-weight: 600;
            padding: 12px;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: 0.3s;
        }

            .btn-login:hover {
                transform: translateY(-3px);
                box-shadow: 0 10px 20px rgba(243, 156, 18, 0.4);
                filter: brightness(1.1);
            }

        .input-group-text {
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: rgba(255,255,255,0.6);
            border-radius: 10px 0 0 10px;
        }
    </style>
</head>
<body>

    <div class="login-card">
        <div class="brand-logo">CAR RENTAL</div>
        <p class="text-center text-white-50 mb-4">Yolculuğunuza devam edin</p>

        <form method="post">
            <div asp-validation-summary="All" class="text-danger small mb-3"></div>

            <div class="mb-3">
                <label class="form-label text-white-50 small">Kullanıcı Adı</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-user"></i></span>
                    <input type="text" asp-for="Username" class="form-control" placeholder="Kullanıcı adınız" required>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label text-white-50 small">Şifre</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-lock"></i></span>
                    <input type="password" asp-for="Password" class="form-control" placeholder="••••••••" required>
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-4">
                <div class="form-check">
                    <input type="checkbox" class="form-check-input" id="rememberMe">
                    <label class="form-check-label small text-white-50" for="rememberMe">Beni Hatırla</label>
                </div>
                <a href="#" class="small text-decoration-none" style="color: #f39c12;">Şifremi Unuttum?</a>
            </div>

            <button type="submit" class="btn btn-login w-100 text-white mb-3">Giriş Yap</button>
        </form>

        <div class="text-center">
            <span class="small text-white-50">Hesabınız yok mu?</span>
            <a href="/Register/Index" class="small text-decoration-none fw-bold" style="color: #f39c12;"> Kayıt Ol</a>
        </div>
    </div>

</body>
</html>