@model CarRental.Dto.RegistersDto.RegisterDto

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Car Rental | Kayıt Ol</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background: linear-gradient(135deg, #1e1e2f 0%, #2d2d44 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            padding: 20px 0;
        }

        .register-card {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            border-radius: 15px;
            padding: 30px;
            width: 100%;
            max-width: 500px; 
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            border: 1px solid rgba(255,255,255,0.1);
        }

        .form-control {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.2);
            color: white;
        }

            .form-control:focus {
                background: rgba(255, 255, 255, 0.1);
                color: white;
                box-shadow: none;
                border-color: #f39c12;
            }

        .form-label {
            font-size: 0.9rem;
            font-weight: 500;
        }

        .btn-register {
            background-color: #f39c12;
            border: none;
            font-weight: bold;
            transition: 0.3s;
        }

            .btn-register:hover {
                background-color: #e67e22;
                transform: translateY(-2px);
            }
    </style>
</head>
<body>

    <div class="register-card">
        <h2 class="text-center mb-3">Yeni Hesap Oluştur</h2>
        <p class="text-center text-secondary small mb-4">Bilgilerinizi girerek hemen üye olun.</p>

        <form method="post">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Adınız</label>
                    <input type="text" asp-for="Name" class="form-control" placeholder="Ad" required>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Soyadınız</label>
                    <input type="text" asp-for="Surname" class="form-control" placeholder="Soyad" required>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">E-posta Adresi</label>
                <input type="email" asp-for="Email" class="form-control" placeholder="ornek@mail.com" required>
            </div>

            <div class="mb-3">
                <label class="form-label">Kullanıcı Adı</label>
                <input type="text" asp-for="Username" class="form-control" placeholder="Kullanıcı adınızı belirleyin" required>
            </div>

            <div class="mb-3">
                <label class="form-label">Şifre</label>
                <input type="password" asp-for="Password" class="form-control" placeholder="••••••••" required>
            </div>

            <div class="d-grid gap-2 mt-4">
                <button type="submit" class="btn btn-register text-white py-2">Kayıt Ol</button>
            </div>
        </form>

        <div class="text-center mt-3">
            <span class="small text-secondary">Zaten hesabınız var mı?</span>
            <a href="/Login/Index" class="small text-decoration-none" style="color: #f39c12;"> Giriş Yap</a>
        </div>
    </div>

</body>
</html>